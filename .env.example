# === API Keys (REQUIRED) ===
OPENAI_API_KEY=sk-your-key-here

# === LLM Backend ===
# Set to "local" to use a local GGUF model (llama-cpp-python) instead of OpenAI
LLM_BACKEND=openai

# === Model Configuration ===
OPENAI_MODEL_REASONING=gpt-4o-mini
OPENAI_MODEL_EXTRACTION=gpt-4o-mini
OPENAI_TEMPERATURE_EXTRACTION=0.0
OPENAI_TEMPERATURE_REASONING=0.2

# === Local GGUF Model (only needed when LLM_BACKEND=local) ===
# LOCAL_MODEL_PATH=/models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
# LOCAL_N_CTX=2048
# LOCAL_N_THREADS=4
# LOCAL_N_GPU_LAYERS=0

# === Paths ===
CORTEX_DATA_PATH=./cortex.parquet

# === MLflow ===
# Omit MLFLOW_TRACKING_URI to use the default file store: <repo>/mlflow-tracking/
# (recommended — avoids SQLite contention with ``mlflow ui``).
# MLFLOW_TRACKING_URI=sqlite:///mlruns.db
MLFLOW_EXPERIMENT_NAME=real_estate_agent
MLFLOW_ENABLED=true
MLFLOW_LOG_ARTIFACTS=false

# === Application ===
LOG_LEVEL=INFO
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
MAX_TOOL_CALLS=3
MAX_TURNS=5

# === KV Cache (REQUIRED) ===
KV_CACHE_ENABLED=true
KV_CACHE_MAX_ENTRIES=50
KV_CACHE_TTL_SECONDS=3600
KV_CACHE_BACKEND=memory
